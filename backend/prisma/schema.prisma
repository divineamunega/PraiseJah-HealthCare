// ============================================================
//  EMR Prisma Schema — Production Ready
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
//  ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  SECRETARY
}

enum ActiveStatus {
  SUSPENDED
  PENDING
  ACTIVE
}

enum QueueStatus {
  WAITING_FOR_VITALS
  READY_FOR_DOCTOR
  ASSIGNED
  IN_PROGRESS
  DONE
}

enum VisitStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum AuditTargetType {
  USER
  PATIENT
  VISIT
  VITAL
  CLINICAL_NOTE
  DIAGNOSIS
  PRESCRIPTION
  LAB_ORDER
  QUEUE_ENTRY
}

// ============================================================
//  USER
// ============================================================

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  status       ActiveStatus @default(PENDING)
  deletedAt    DateTime? // Soft delete
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  auditLogsAsActor AuditLog[]   @relation("ActorAuditLogs")
  visits           Visit[]      @relation("VisitDoctor")
  queueEntries     QueueEntry[]

  // === Auditing fields (very important for admins) ===
  createdById    String? // Who created this user (admin)
  createdBy      User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  usersCreatedBy User[]  @relation("UserCreatedBy")
  updatedById    String? // Who last updated this user
  updatedBy      User?   @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  usersUpdatedBy User[]  @relation("UserUpdatedBy")

  refreshTokens RefreshToken[]

  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique // hashed refresh token (never plain text)
  expiresAt DateTime
  revokedAt DateTime? // null = still valid

  // === Auditing / Session tracking fields ===
  ipAddress     String? // IP from which user logged in
  userAgent     String? // Browser / device info (e.g. "Chrome on Windows")
  deviceInfo    String? // Optional: "iPhone 15", "MacBook Pro", etc.
  correlationId String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([correlationId])
  @@map("refresh_tokens")
}

// ============================================================
//  PATIENT
// ============================================================

model Patient {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  sex         Sex
  phone       String?
  address     String?
  deletedAt   DateTime? // Soft delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  visits Visit[]

  @@index([firstName, lastName, dateOfBirth])
  @@map("patients")
}

// ============================================================
//  VISIT
// ============================================================

model Visit {
  id        String      @id @default(uuid())
  patientId String
  doctorId  String?
  status    VisitStatus @default(CREATED)
  deletedAt DateTime? // Soft delete
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  doctor        User?          @relation("VisitDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  queueEntry    QueueEntry?
  vitals        Vital[]
  clinicalNotes ClinicalNote[]
  diagnoses     Diagnosis[]
  prescriptions Prescription[]
  labOrders     LabOrder[]

  @@index([patientId, createdAt])
  @@index([doctorId])
  @@index([status])
  @@map("visits")
}

// ============================================================
//  QUEUE ENTRY
// ============================================================

model QueueEntry {
  id        String      @id @default(uuid())
  visitId   String      @unique
  userId    String? // Nurse or Doctor who last acted
  status    QueueStatus @default(WAITING_FOR_VITALS)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("queue_entries")
}

// ============================================================
//  VITAL
// ============================================================

model Vital {
  id                 String    @id @default(uuid())
  visitId            String
  recordedById       String?
  systolicBP         Int?
  diastolicBP        Int?
  heartRate          Int?
  respiratoryRate    Int?
  temperatureCelsius Decimal?  @db.Decimal(4, 1)
  weightKg           Decimal?  @db.Decimal(5, 2)
  heightCm           Decimal?  @db.Decimal(5, 2)
  recordedAt         DateTime  @default(now())
  deletedAt          DateTime? // Soft delete

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("vitals")
}

// ============================================================
//  CLINICAL NOTE
// ============================================================

model ClinicalNote {
  id        String    @id @default(uuid())
  visitId   String
  authorId  String? // Doctor
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("clinical_notes")
}

// ============================================================
//  DIAGNOSIS
// ============================================================

model Diagnosis {
  id          String    @id @default(uuid())
  visitId     String
  authorId    String?
  code        String? // ICD-10 code
  description String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime? // Soft delete

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("diagnoses")
}

// ============================================================
//  PRESCRIPTION
// ============================================================

model Prescription {
  id           String    @id @default(uuid())
  visitId      String
  prescriberId String?
  medication   String
  dosage       String
  frequency    String
  duration     String?
  notes        String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime? // Soft delete

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("prescriptions")
}

// ============================================================
//  LAB ORDER
// ============================================================

model LabOrder {
  id          String    @id @default(uuid())
  visitId     String
  orderedById String?
  testName    String
  notes       String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime? // Soft delete

  // Relations
  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@map("lab_orders")
}

// ============================================================
//  AUDIT LOG
// ============================================================

model AuditLog {
  id String @id @default(uuid())

  // Who performed the action (the staff member)
  actorId String?
  actor   User?   @relation("ActorAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  // What was affected
  targetType AuditTargetType?
  targetId   String?

  // Action details
  action   String // e.g. "USER_CREATED", "VISIT_UPDATED", "VITALS_RECORDED", "LOGIN_SUCCESS"
  entity   String? // You can keep this or turn it into an enum later
  entityId String?

  // Rich context (very useful for EMR auditing)
  metadata Json? // Store { oldValues: {...}, newValues: {...}, reason: "..." }

  // Request / Session info
  ipAddress     String?
  userAgent     String?
  correlationId String?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@index([correlationId])
  @@map("audit_logs")
}
